---
import { Image } from "astro:assets";
import FormattedDate from "./FormattedDate.astro";
import type { postsArrayType } from "@/types";

export type Props = postsArrayType;

const { posts } = Astro.props;
---

{
    posts.map((post, index) => {
        return (
            <a
                title={post.data.pin ? post.data.title : null}
                href={`/${post.lang}/blog/${post.slug}`}
                data-tooltip-placement="top"
                class="grid row-span-3 [grid-template-rows:1fr_auto_auto]"
            >
                {post.data.heroImage && (
                    <Image
                        src={post.data.heroImage}
                        loading={index < 4 ? "eager" : "lazy"}
                        widths={[400, 800, 1200]}
                        sizes="(max-width: 768px) 100vw, 800px"
                        alt=""
                    />
                )}
                <div>
                    <h4 class="font-[Editorial] pt-4">{post.data.title}</h4>
                    <p>
                        <FormattedDate date={post.data.pubDate} />
                    </p>
                </div>
            </a>
        );
    })
}
