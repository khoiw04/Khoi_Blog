---
import Newsletter from "@/components/presenters/newsletter.index.tsx";
import { useGetTranslations } from "@/i18n";

const { showRegister = true } = Astro.props;
const configTranslations = useGetTranslations(Astro);
---

<footer class="z-50 text-foreground text-center w-full max-w-[720px] mx-auto">
    <section class="gap-4 border-b">
        <div
            class="font-[Atkinson] px-4 h-8 flex flex-row justify-between items-center"
        >
            <span class="text-sm">&copy; Khoi.</span>
            <div class="flex flex-row gap-4">
                <a
                    href="https://discord.gg/NcuCYAjdp2"
                    target="_blank"
                    title="Discord"
                    data-tooltip-placement="top"
                >
                    <span class="sr-only">Follow Khoi on Discord</span>
                    <svg
                        role="img"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                        width="14"
                        height="14"
                        astro-icon="social/discord"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            fill="currentColor"
                            d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="https://www.youtube.com/@khoiwn04"
                    target="_blank"
                    title="YouTube"
                    data-tooltip-placement="top"
                >
                    <span class="sr-only">Follow Khoi on YouTube</span>
                    <svg
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                        width="14"
                        height="14"
                        astro-icon="social/youtube"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            fill="currentColor"
                            d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                        ></path>
                    </svg>
                </a>
                <a
                    href="https://github.com/khoiw04"
                    target="_blank"
                    title="Github"
                    data-tooltip-placement="top"
                >
                    <span class="sr-only">Go to Khoi's GitHub repo</span>
                    <svg
                        viewBox="0 0 16 16"
                        aria-hidden="true"
                        width="14"
                        height="14"
                        astro-icon="social/github"
                        ><path
                            fill="currentColor"
                            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                        ></path></svg
                    >
                </a>
            </div>
            <span class="text-sm">
                (2026/02/21)
                <a
                    href="/en/changelog"
                    class="underline"
                    title="Go to Changelog"
                    data-tooltip-placement="right">v0.0.4</a
                >
            </span>
        </div>
    </section>
    {
        showRegister && (
            <Newsletter
                configTranslations={configTranslations}
                client:visible
            />
        )
    }
</footer>
