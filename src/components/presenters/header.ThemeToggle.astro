---
import { Button } from "@/components/ui/button";
import { useGetTranslations } from "@/i18n";

const configTranslations = useGetTranslations(Astro);
const labelLight = configTranslations.tooltipNavbarLightThemeOn; // Text: "Bật giao diện sáng"
const labelDark = configTranslations.tooltipNavbarLightThemeOff; // Text: "Bật giao diện tối"
---

<Button
    variant="ghost"
    size="icon"
    id="themeButton"
    title={labelLight}
    data-label-light={labelLight}
    data-label-dark={labelDark}
>
    <label
        for="toggletheme"
        class="swap swap-rotate **:block size-full **:size-full relative text-foreground cursor-default"
    >
        <input
            type="checkbox"
            class="theme-controller absolute -translate-1"
            value="synthwave"
            id="themeToggle"
            tabindex="2"
        />
        <span class="sr-only">Theme Toogle</span>
        <svg
            class="swap-off h-10 w-10 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
        >
            <path
                d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
            ></path>
        </svg>

        <svg
            class="swap-on h-10 w-10 fill-current"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
        >
            <path
                d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
            ></path>
        </svg>
    </label>
</Button>

<script is:inline data-astro-rerun>
    (() => {
        const applyTheme = (isDark) => {
            const root = document.documentElement;
            const themeButton = document.getElementById("themeButton");

            // 1. Thay đổi class theme
            if (isDark) {
                root.classList.add("dark");
            } else {
                root.classList.remove("dark");
            }

            // 2. Cập nhật nội dung Tooltip
            if (themeButton) {
                // Nếu đang tối thì hiện text "Bật giao diện sáng" và ngược lại
                const nextLabel = isDark
                    ? themeButton.dataset.labelLight
                    : themeButton.dataset.labelDark;

                themeButton.title = nextLabel;

                // Cập nhật cho astro-tooltips (Tippy.js)
                if (themeButton._tippy) {
                    themeButton._tippy.setContent(nextLabel);
                }
            }

            updateColorSchemeMeta(isDark);
        };

        // ... các hàm phụ trợ giữ nguyên ...
        const updateColorSchemeMeta = (isDark) => {
            /* giữ nguyên */
        };
        const getStoredOrPreferredTheme = () => {
            /* giữ nguyên */
        };

        const setInitialTheme = () => {
            const theme = getStoredOrPreferredTheme();
            const isDark = theme === "dark";

            const themeToggle = document.getElementById("themeToggle");
            if (themeToggle) {
                themeToggle.checked = isDark;
            }

            // Delay nhẹ để astro-tooltips kịp khởi tạo
            setTimeout(() => applyTheme(isDark), 100);
        };

        const setupToggleButton = () => {
            const themeToggle = document.getElementById("themeToggle");
            if (!themeToggle) return;

            themeToggle.onclick = () => {
                const isCurrentlyDark =
                    document.documentElement.classList.contains("dark");
                const nextIsDark = !isCurrentlyDark;

                applyTheme(nextIsDark);
                localStorage.setItem("theme", nextIsDark ? "dark" : "light");
            };

            // ... logic keydown giữ nguyên ...
        };

        setInitialTheme();
        setupToggleButton();

        document.addEventListener("astro:after-swap", () => {
            setInitialTheme();
            setupToggleButton();
        });
    })();
</script>
