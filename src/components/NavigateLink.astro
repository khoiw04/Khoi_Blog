---
import type { HTMLAttributes } from 'astro/types';
type Props = HTMLAttributes<'button'>;

const { name = 'Quay lại', class: className, ...props } = Astro.props;
---

<button {...props} type="button" onclick="if (document.referrer) history.back(); else window.location.href='/'" class:list={["flex flex-row gap-2 items-center", className]}>
	<svg
		xmlns="http://www.w3.org/2000/svg" 
		width="16" 
		height="16" 
		viewBox="0 0 24 24" 
		fill="none" 
		stroke="currentColor" 
		stroke-width="2" 
		stroke-linecap="round" 
		stroke-linejoin="round" 
		class="lucide lucide-arrow-left-icon lucide-arrow-left">
			<path d="m12 19-7-7 7-7"/>
			<path d="M19 12H5"/>
	</svg>
	<span class="translate-y-0.5 hidden md:block">{name}</span>
</button>