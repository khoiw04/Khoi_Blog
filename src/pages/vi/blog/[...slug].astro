---
import { type CollectionEntry, render } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import { getSortedVietnamBlog } from "@/lib";
import TOCHeader from "@/components/Layouts/TOCHeader.astro";
import UnpicMarkdown from "@/components/Layouts/UnpicMarkdown.astro";

export const prerender = true;
export async function getStaticPaths() {
    const posts = await getSortedVietnamBlog();
    return posts.map((post) => {
        return {
            params: { lang: post.lang, slug: post.slug },
            props: post,
        };
    });
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await render(post);
---

<BlogLayout {...post.data}>
    {
        headings?.length > 0 &&
            !(
                headings.length === 1 && headings[0].text === post.data.title
            ) && <TOCHeader slot="table-of-contents" headings={headings} />
    }
    <Content components={{ img: UnpicMarkdown }} />
</BlogLayout>
