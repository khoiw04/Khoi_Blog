---
import BaseHead from '@/components/HeadSeo.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import NavigateLink from '@/components/NavigateLink.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="sticky top-10 mb-5 md:mb-0 md:top-20.25 flex flex-row justify-between">
				<NavigateLink class='md:mb-8' />
			</header>
			<section class="text-primary">
                <h1 class="font-bold mb-4">404 - Không tìm thấy trang</h1>
                <p class="mb-6">Trang bạn đang tìm không tồn tại hoặc đã bị di chuyển.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
