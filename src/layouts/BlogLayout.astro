---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/Layouts/HeadSeo.astro";
import Footer from "@/components/Layouts/Footer.astro";
import FormattedDate from "@/components/Layouts/FormattedDate.astro";
import Header from "@/components/Layouts/Header.astro";
import { useGetTranslations } from "@/i18n";
import LayoutBlog from "@/components/Layouts/LayoutBlog.astro";
import WalineComments from "@/components/Layouts/WalineComments.astro";
import ImageViewer from "@/components/Layouts/ImageViewer.astro";
import { themeConfig } from "@/config";
import { Picture } from "astro:assets";

type Props = CollectionEntry<"blog">["data"];

const path = Astro.url.pathname;
const configTranslations = useGetTranslations(Astro);
const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang={configTranslations.lang as string}>
    <head>
        <!-- Thanks to Chiri for Code Template -->
        <!-- Thanks to Enscribe.dev for TOB Template -->
        <!-- Thanks to wwanname for Effect Template -->
        <!-- Thanks to devaslife for Grid Template -->
        <BaseHead title={title} image={heroImage} description={description} />
        <LayoutBlog />
    </head>
    <body>
        <Header hiddenBorder={false}>
            <slot name="table-of-contents" />
        </Header>
        <main>
            <article>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <h1 class="font-[Editorial]">{title}</h1>
                            <span
                                class="flex flex-row items-center justify-center"
                            >
                                <FormattedDate date={pubDate} />
                                <span class="mx-2">•</span>
                                <p class="my-0!">
                                    <span
                                        class="waline-pageview-count"
                                        data-path={path}>0</span
                                    >
                                    view
                                </p>
                            </span>
                        </div>
                        <hr />
                    </div>
                    {
                        heroImage && (
                            <div class="hero-image">
                                <Picture
                                    src={heroImage}
                                    formats={["avif", "webp"]}
                                    alt=""
                                    sizes="(min-width: 1024px) 1024px, 100vw"
                                />
                            </div>
                        )
                    }
                    <slot />
                    {!path.endsWith("/form") && <WalineComments />}
                </div>
            </article>
            {themeConfig.post.imageViewer && <ImageViewer />}
        </main>
        {themeConfig.general.footer && <Footer hiddenBorder={false} />}
    </body>
</html>
