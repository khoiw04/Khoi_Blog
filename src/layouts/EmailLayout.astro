---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/Layouts/FormattedDate.astro";
import { useGetTranslations } from "@/i18n";

type Props = CollectionEntry<"blog">["data"];

const configTranslations = useGetTranslations(Astro);
const { title, pubDate, heroImage, postUrl } = Astro.props;
const unsubscribeLink = `${import.meta.env.PUBLIC_SITE_URL}/unsubscribe?email={{USER_EMAIL}}`;
---

<html lang={configTranslations.lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="robots" content="noindex, nofollow" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    </head>
    <body>
        <main>
            <article>
                <div class="mail">
                    <div class="title">
                        <div class="date">
                            <a href={postUrl}>
                                <h1>{title}</h1>
                            </a>
                            <FormattedDate date={pubDate} />
                        </div>
                        <hr />
                    </div>
                    {
                        heroImage && (
                            <div class="hero-image">
                                <a
                                    href={postUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <img
                                        src={heroImage}
                                        alt={Astro.props.title || ""}
                                        style="display:block; width:100%; max-width:600px; height:auto; border-radius:8px;"
                                    />
                                </a>
                            </div>
                        )
                    }
                    <div class="content">
                        <slot />
                    </div>
                </div>
            </article>
            <footer class="footer-content">
                <span>
                    {configTranslations.unsubscribeDescription}
                </span>
                <a
                    href={unsubscribeLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    >{configTranslations.unsubscribeButton}</a
                >
            </footer>
        </main>
    </body>
</html>

<style is:inline>
    /* Reset cơ bản cho Email client */
    #outlook a {
        padding: 0;
    }
    body {
        width: 100% !important;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        margin: 0;
        padding: 0;
        background-color: #f6f6f6;
        font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
            Arial, sans-serif;
    }

    /* Container chính cố định 600px */
    .mail {
        width: 600px;
        max-width: 600px;
        margin: 40px auto;
        padding: 40px;
        background-color: #ffffff;
        border-radius: 16px;
        border: 1px solid #eeeeee;
        color: #111111;
        line-height: 24px;
    }

    /* Tiêu đề & Ngày tháng */
    .title {
        margin-bottom: 30px;
    }

    .title h1 {
        font-size: 32px;
        font-weight: bold;
        line-height: 38px;
        margin: 0 0 10px 0;
        color: #000000;
    }

    .date {
        font-size: 14px;
        color: #666666;
        margin-bottom: 15px;
    }

    hr {
        border: 0;
        border-top: 1px solid #eeeeee;
        margin: 20px 0;
    }

    /* Hình ảnh */
    img {
        max-width: 100% !important;
        height: auto !important;
    }

    .hero-image img {
        width: 100% !important;
        max-width: 600px !important;
        height: auto;
        border-radius: 8px;
        display: block;
        margin-bottom: 30px;
    }

    .content img {
        max-width: 100% !important;
        height: auto !important;
        display: block;
        margin: 20px auto;
        border-radius: 8px;
    }

    figure,
    .image-caption-wrapper {
        margin: 20px 0;
        padding: 0;
        width: 100% !important;
        max-width: 100% !important;
        overflow: hidden;
        display: block;
    }

    figure img,
    .image-caption-wrapper img {
        margin: 0 auto !important;
        width: 100% !important;
        max-width: 100% !important;
        height: auto !important;
        display: block;
    }

    figcaption,
    .img-caption {
        font-size: 13px;
        color: #888888;
        text-align: center;
        margin-top: 10px;
        line-height: 1.4;
    }

    /* Typography cho Nội dung (Slot) */
    p {
        font-size: 16px;
        line-height: 26px;
        margin-top: 0;
        margin-bottom: 20px;
        color: #333333;
    }

    h2 {
        font-size: 24px;
        line-height: 30px;
        font-weight: bold;
        margin-top: 40px;
        margin-bottom: 15px;
        color: #000000;
    }

    h3 {
        font-size: 20px;
        line-height: 26px;
        font-weight: bold;
        margin-top: 30px;
        margin-bottom: 12px;
        color: #000000;
    }

    a {
        color: #000000;
        text-decoration: underline;
    }

    /* Lists */
    ul,
    ol {
        margin-top: 0;
        margin-bottom: 20px;
        padding-left: 25px;
    }

    li {
        font-size: 16px;
        line-height: 26px;
        margin-bottom: 8px;
        color: #333333;
    }

    /* Blockquotes */
    blockquote {
        margin: 25px 0;
        padding: 10px 20px;
        border-left: 4px solid #dddddd;
        background-color: #fcfcfc;
    }

    blockquote p {
        margin-bottom: 0 !important;
        font-style: italic;
        color: #555555;
    }

    /* Code Blocks */
    code {
        font-family: "Courier New", Courier, monospace;
        background-color: #f4f4f4;
        padding: 2px 5px;
        border-radius: 3px;
        font-size: 14px;
    }

    pre {
        background-color: #222222;
        color: #ffffff;
        padding: 15px;
        border-radius: 6px;
        overflow-x: auto;
        margin: 20px 0;
    }

    pre code {
        background-color: transparent;
        color: #ffffff;
        padding: 0;
        font-size: 13px;
        line-height: 20px;
    }

    /* Responsive cho Mobile */
    @media only screen and (max-width: 600px) {
        .mail {
            width: 100% !important;
            margin: 0 !important;
            padding: 20px !important;
            border-radius: 0 !important;
            border: none !important;
        }
        .hero-image img,
        .content img,
        figure,
        figure img,
        .image-caption-wrapper,
        .image-caption-wrapper img {
            width: 100% !important;
            height: auto !important;
        }
        .title h1 {
            font-size: 26px !important;
            line-height: 32px !important;
        }
    }

    .footer-content {
        width: 600px;
        max-width: 600px;
        margin: 40px auto;
        padding: 40px;
        text-align: center;
    }

    .footer-content span {
        display: block;
    }
</style>
