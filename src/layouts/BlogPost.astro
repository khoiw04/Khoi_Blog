---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '@/components/HeadSeo.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import NavigateLink from '@/components/NavigateLink.astro';
import { getLangFromUrl, useGetTranslations, useLang, useTranslations } from '@/i18n/utils';


type Props = CollectionEntry<'blog'>['data'];

const configTranslations = useGetTranslations(Astro)
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang={configTranslations.lang}>
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 4em;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
			}
			.prose {
				width: 720px;
				max-width: 100%;
				margin: auto;
			}
			.title {
				margin-top: 1.4em;
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<NavigateLink name={configTranslations.navigateBack} />
				<div class="prose">
					<div class="title">
						<div class="date">
							<h1 class="font-[Editorial]">{title}</h1>
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<hr />
					</div>
					<div class="hero-image">
						{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
